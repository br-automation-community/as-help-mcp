# B&R Automation Studio Help Server Configuration

# REQUIRED: Path to the B&R Help Data directory containing brhelpcontent.xml
# WSL/Linux: /mnt/c/Program Files (x86)/BRAutomation/AS6/Help-en/Data
# Windows: C:\Program Files (x86)\BRAutomation\AS6\Help-en\Data
AS_HELP_ROOT=C:\Program Files (x86)\BRAutomation\AS6\Help-en\Data

# OPTIONAL: Path to LanceDB directory for search index
# Defaults to .ashelp_lance in the help root directory
# The database is automatically rebuilt only when brhelpcontent.xml changes
# AS_HELP_DB_PATH=data\.ashelp_lance

# OPTIONAL: Path to directory for index metadata and change detection
# Defaults to .ashelp_metadata in the help root directory
# AS_HELP_METADATA_DIR=data\.ashelp_metadata

# === OPTIONAL: Embedding API for Hybrid Semantic Search ===
# By default, only keyword (FTS) search is used. Set CREATE_EMBEDDINGS=true
# to enable hybrid search (semantic + keyword) via an OpenAI-compatible embedding API.
# This works with: OpenAI, Azure OpenAI, GitHub Models, Ollama, LiteLLM, etc.
#
# CREATE_EMBEDDINGS=false
#
# --- GitHub Models (free with GitHub PAT) ---
# EMBEDDING_API_ENDPOINT=https://models.inference.ai.azure.com
# EMBEDDING_API_KEY=ghp_your_github_personal_access_token
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
#
# --- OpenAI ---
# EMBEDDING_API_ENDPOINT=https://api.openai.com
# EMBEDDING_API_KEY=sk-your-openai-key
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
#
# --- Azure OpenAI ---
# EMBEDDING_API_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/your-deployment
# EMBEDDING_API_KEY=your-azure-key
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
#
# --- Ollama (local) ---
# EMBEDDING_API_ENDPOINT=http://localhost:11434
# EMBEDDING_API_KEY=unused
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIMENSIONS=768
#
# Advanced embedding settings:
# EMBEDDING_BATCH_SIZE=100
# EMBEDDING_MAX_CHARS=8000
# EMBEDDING_MAX_WORKERS=4

# OPTIONAL: Force rebuild the search index even if it exists (default: false)
# Set to "true" when you've updated help files or want to ensure a fresh index
# After first run, this can remain false for fast startup
AS_HELP_FORCE_REBUILD=false

# OPTIONAL: Automation Studio version for online help links (default: 6)
# Choices: 4, 6
AS_HELP_VERSION=6

# === OPTIONAL: Transport Configuration ===
# MCP transport mode. Supported: "stdio" (default), "streamable-http"
# Note: "sse" is NOT supported and will produce a helpful error message.
# MCP_TRANSPORT=stdio

# Host and port for streamable-http transport (ignored for stdio)
# MCP_HOST=127.0.0.1
# MCP_PORT=8000

# Disable DNS rebinding protection for streamable-http transport
# Only set to true if you need to bind to a non-loopback host (e.g., 0.0.0.0)
# MCP_DISABLE_DNS_REBINDING_PROTECTION=false

