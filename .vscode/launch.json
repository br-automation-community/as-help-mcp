{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Server (Debug)",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": ["build", "--bin=as-help-server"]
      },
      "args": [
        "--help-root",
        "C:\\Program Files (x86)\\BRAutomation\\AS6\\Help-en\\Data",
        "--db-path",
        "${env:APPDATA}\\as-help-mcp\\data\\as6\\.ashelp_lance",
        "--metadata-dir",
        "${env:APPDATA}\\as-help-mcp\\data\\as6\\.ashelp_metadata",
        "--as-version",
        "6"
      ],
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Run Tests",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": ["test", "--no-run"]
      },
      "cwd": "${workspaceFolder}"
    }
  ]
}
